# Environment variables for running the workspace examples.
# Library crates do not read environment variables — all configuration is passed explicitly through constructors.

# --- DeepSeek ---
#JUST_LLM_DEEPSEEK_API_KEY=
#JUST_LLM_DEEPSEEK_MODEL=
# default: https://api.deepseek.com/v1
#JUST_LLM_DEEPSEEK_BASE_URL=

# --- OpenAI-compatible ---
#JUST_LLM_OPENAI_COMPAT_API_KEY=
#JUST_LLM_OPENAI_COMPAT_BASE_URL=
#JUST_LLM_OPENAI_COMPAT_MODEL=

# --- Runtime provider selection ---
# When using just-llm-client's runtime provider selection, one of the above
# provider groups must also be configured.
#JUST_LLM_PROVIDER=
#JUST_LLM_MODEL=
